#!/usr/bin/env bash
set -euo pipefail

CANONICAL_STATUSES=("inbox" "ready" "in-progress" "needs-review" "blocked" "needs-info" "done")

usage() {
  cat <<EOF
Usage: board-sync --issue N --status STATUS [--repo OWNER/REPO]

Write ONE GitHub issue's status by swapping its canonical status label:
remove the old canonical label, add the target canonical label.
Non-canonical labels (enhancement, bug, …) are left untouched.
Idempotent: if the issue already has the target status, it is a no-op.

Options:
  --issue N      GitHub issue number (required).
  --status STATUS  Target canonical status (required).
                 Valid: ${CANONICAL_STATUSES[*]}
  --repo OWNER/REPO  Repository (or set BOARD_REPO env var).
EOF
  exit 0
}

# compute_label_changes <target_status> <current_labels_csv>
#
# Pure function (no network) — determines which canonical label to remove
# and which to add. Prints one of:
#   "NOOP"                        — target already present, no change needed
#   "REMOVE=<old> ADD=<target>"   — swap <old> canonical for <target>
# where <old> may be empty (no canonical label currently on the issue).
compute_label_changes() {
  local target="$1" labels_csv="$2"

  # Idempotent: target already on the issue
  if echo "$labels_csv" | tr ',' '\n' | grep -qxF "$target"; then
    echo "NOOP"
    return
  fi

  # Find the first existing canonical label (there should be at most one)
  local old=""
  for lbl in "${CANONICAL_STATUSES[@]}"; do
    if echo "$labels_csv" | tr ',' '\n' | grep -qxF "$lbl"; then
      old="$lbl"
      break
    fi
  done

  echo "REMOVE=${old} ADD=${target}"
}

# --- Parse args ---
ISSUE=""
STATUS=""
REPO="${BOARD_REPO:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue) ISSUE="$2"; shift 2 ;;
    --status) STATUS="$2"; shift 2 ;;
    --repo) REPO="$2"; shift 2 ;;
    --help|-h) usage ;;
    *) echo "Unknown flag: $1"; usage ;;
  esac
done

if [[ -z "$ISSUE" ]]; then
  echo "ERROR: --issue is required." >&2
  usage
fi

if [[ -z "$STATUS" ]]; then
  echo "ERROR: --status is required." >&2
  usage
fi

# Validate STATUS
valid=0
for s in "${CANONICAL_STATUSES[@]}"; do
  if [[ "$STATUS" == "$s" ]]; then
    valid=1
    break
  fi
done
if [[ $valid -eq 0 ]]; then
  echo "ERROR: invalid status '$STATUS'. Valid: ${CANONICAL_STATUSES[*]}" >&2
  exit 1
fi

if [[ -z "$REPO" ]]; then
  echo "ERROR: --repo or BOARD_REPO is required." >&2
  exit 1
fi

if ! command -v gh &>/dev/null; then
  echo "ERROR: gh (GitHub CLI) is not installed or not on PATH." >&2
  exit 1
fi

# Fetch current labels
if ! labels_json=$(gh issue view "$ISSUE" --repo "$REPO" --json labels 2>/dev/null); then
  echo "ERROR: failed to fetch labels for issue #${ISSUE} on ${REPO}" >&2
  exit 1
fi

current_labels_csv=$(echo "$labels_json" | jq -r '[.labels[].name] | join(",")')

# Compute changes
result=$(compute_label_changes "$STATUS" "$current_labels_csv")

if [[ "$result" == "NOOP" ]]; then
  echo "#${ISSUE}: already ${STATUS}"
  exit 0
fi

# Parse REMOVE=... ADD=...
old="${result#REMOVE=}"
old="${old%% ADD=*}"
new="${result##*ADD=}"

echo "syncing #${ISSUE} -> ${STATUS} on ${REPO}" >&2

# Build gh edit args
edit_args=(--repo "$REPO" --add-label "$new")
if [[ -n "$old" ]]; then
  edit_args+=(--remove-label "$old")
fi

if ! gh issue edit "$ISSUE" "${edit_args[@]}" 2>/dev/null; then
  echo "ERROR: failed to update issue #${ISSUE}" >&2
  exit 1
fi

if [[ -n "$old" ]]; then
  echo "#${ISSUE}: ${old} -> ${STATUS}"
else
  echo "#${ISSUE}: (none) -> ${STATUS}"
fi
