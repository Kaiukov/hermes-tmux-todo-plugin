#!/usr/bin/env python3
"""board-render: Read .tasks/issues.json, write .tasks/board.json and TODO.md."""
import json
import sys
from pathlib import Path

# Canonical status order
STATUS_ORDER = [
    "inbox",
    "ready",
    "in-progress",
    "needs-review",
    "blocked",
    "needs-info",
    "done",
]

def derive_status(labels: list[dict] | list[str]) -> str:
    """Derive canonical status from a list of labels (GitHub API format).

    Walks STATUS_ORDER in reverse so the most-progressed status wins
    when an issue has multiple status labels (e.g. both inbox and ready).
    Legacy 'completed' label maps to 'done'.
    """
    label_names = set()
    for label in labels:
        if isinstance(label, dict):
            name = label.get("name", "").lower()
        else:
            name = str(label).lower()
        label_names.add(name)

    # Reverse walk: most-progressed status wins (last match in canonical order)
    for status in reversed(STATUS_ORDER):
        if status in label_names:
            return status

    # Check legacy completed
    if "completed" in label_names:
        return "done"

    return "inbox"  # default fallback


def render(input_path: Path, board_path: Path, todo_path: Path) -> int:
    """Read issues.json, write board.json / TODO.md / .tasks/issues/<n>.md.
    Returns count of issue body files written."""

    with open(input_path) as f:
        issues = json.load(f)

    if not isinstance(issues, list):
        print(f"board-render: expected JSON array, got {type(issues).__name__}",
              file=sys.stderr)
        sys.exit(1)

    # Build board list
    board = []
    for issue in issues:
        number = issue.get("number", 0)
        title = issue.get("title", "untitled")
        labels = issue.get("labels") or []
        status = derive_status(labels)
        url = issue.get("url", "")
        assignees_raw = issue.get("assignees") or []
        assignee_names = []
        for a in assignees_raw:
            if isinstance(a, dict):
                assignee_names.append(a.get("login", ""))
            else:
                assignee_names.append(str(a))

        board.append({
            "number": number,
            "id": None,
            "title": title,
            "status": status,
            "labels": [lbl.get("name", str(lbl)) if isinstance(lbl, dict) else str(lbl)
                       for lbl in labels],
            "url": url,
            "assignees": assignee_names,
            "source": "github",
        })

    # Merge local tasks from .tasks/local.json
    local_path = input_path.parent / "local.json"
    if local_path.exists():
        with open(local_path) as f:
            local_tasks = json.load(f)
        if isinstance(local_tasks, list) and len(local_tasks) > 0:
            for lt in local_tasks:
                lt_status = lt.get("status", "inbox")
                if lt_status not in STATUS_ORDER:
                    lt_status = "inbox"
                board.append({
                    "number": None,
                    "id": lt.get("id", "L?"),
                    "title": lt.get("title", "untitled"),
                    "status": lt_status,
                    "labels": [],
                    "url": "",
                    "assignees": [],
                    "source": "local",
                })

    # Deterministic sort: by canonical status order, then github first by number,
    # then local by numeric id suffix
    status_rank = {s: i for i, s in enumerate(STATUS_ORDER)}

    def sort_key(t):
        status_key = status_rank.get(t["status"], 99)
        is_github = 0 if t["number"] is not None else 1
        num = t["number"] if t["number"] is not None else 0
        if t.get("id") and t["number"] is None:
            try:
                num = int(str(t["id"]).lstrip("L"))
            except ValueError:
                num = 0
        return (status_key, is_github, num)

    board.sort(key=sort_key)

    # Ensure .tasks directory exists
    board_path.parent.mkdir(parents=True, exist_ok=True)

    # Write board.json
    with open(board_path, "w") as f:
        json.dump(board, f, indent=2)
        f.write("\n")

    # Group by status for TODO.md
    groups: dict[str, list[dict]] = {s: [] for s in STATUS_ORDER}
    for task in board:
        groups[task["status"]].append(task)

    # Build TODO.md lines
    lines = []
    lines.append("<!-- generated by board-render -- do not edit -->")
    lines.append("")
    lines.append("# Task Board")
    lines.append("")

    for status in STATUS_ORDER:
        tasks = groups.get(status, [])
        if not tasks:
            continue
        lines.append(f"## {status}")
        lines.append("")
        for t in tasks:
            if t.get("source") == "local":
                lines.append(f"- [ ] [{t['id']}] {t['title']}")
            else:
                assignee_str = ""
                if t["assignees"]:
                    assignee_str = " (@" + ", @".join(t["assignees"]) + ")"
                lines.append(f"- [ ] [#{t['number']}] {t['title']}{assignee_str}")
        lines.append("")

    with open(todo_path, "w") as f:
        f.write("\n".join(lines) + "\n")

    # Persist per-issue bodies to .tasks/issues/<n>.md
    issues_dir = board_path.parent / "issues"
    issues_dir.mkdir(parents=True, exist_ok=True)
    issue_body_count = 0
    for task in board:
        if task["source"] != "github":
            continue
        num = task["number"]
        title = task["title"]
        url = task["url"]
        status = task["status"]
        labels_str = ", ".join(task["labels"]) if task["labels"] else ""
        body = None
        for iss in issues:
            if iss.get("number") == num:
                body = iss.get("body")
                break
        md_path = issues_dir / f"{num}.md"
        with open(md_path, "w") as f:
            f.write(f"# #{num} {title}\n\n")
            f.write(f"URL: {url}\n")
            f.write(f"Status: {status}\n")
            f.write(f"Labels: {labels_str}\n")
            f.write("\n## Body\n\n")
            if body is not None:
                f.write(str(body))
            else:
                f.write("(no body)")
            f.write("\n")
        issue_body_count += 1

    return issue_body_count


def main() -> None:
    root = Path.cwd()
    input_file = root / ".tasks" / "issues.json"
    board_file = root / ".tasks" / "board.json"
    todo_file = root / "TODO.md"

    if not input_file.exists():
        print(f"board-render: {input_file} not found. Run board-pull first.",
              file=sys.stderr)
        sys.exit(1)

    issue_body_count = render(input_file, board_file, todo_file)

    # Print summary to stderr
    with open(board_file) as f:
        board = json.load(f)
    total = len(board)
    ready = sum(1 for t in board if t["status"] == "ready")
    blocked = sum(1 for t in board if t["status"] == "blocked")
    in_progress = sum(1 for t in board if t["status"] == "in-progress")
    print(
        f"board-render: {total} tasks → .tasks/board.json + TODO.md "
        f"(ready={ready}, in-progress={in_progress}, blocked={blocked})"
        f" +{issue_body_count} issue bodies",
        file=sys.stderr)


if __name__ == "__main__":
    main()
