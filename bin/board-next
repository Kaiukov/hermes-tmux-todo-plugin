#!/usr/bin/env bash
set -euo pipefail

CANONICAL_STATUSES=("inbox" "ready" "in-progress" "needs-review" "blocked" "needs-info" "done")

usage() {
  cat <<EOF
Usage: board-next [--status STATUS] [--json] [--help|-h]

Return the next actionable task for a given status from .tasks/board.json.

Options:
  --status STATUS  Canonical status (default: ready).
                   Valid: inbox, ready, in-progress, needs-review, blocked, needs-info, done
  --json           Machine-readable JSON output (full board.json entry)
  --help, -h       Show this help message
EOF
  exit 0
}

STATUS="ready"
JSON_MODE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status) STATUS="$2"; shift 2 ;;
    --json) JSON_MODE=1; shift ;;
    --help|-h) usage ;;
    *) echo "board-next: unknown flag: $1" >&2; usage ;;
  esac
done

valid=0
for s in "${CANONICAL_STATUSES[@]}"; do
  if [[ "$STATUS" == "$s" ]]; then
    valid=1
    break
  fi
done
if [[ $valid -eq 0 ]]; then
  echo "board-next: invalid status '$STATUS'. Valid: ${CANONICAL_STATUSES[*]}" >&2
  exit 1
fi

BOARD_FILE=".tasks/board.json"

if [[ ! -f "$BOARD_FILE" ]]; then
  echo "board-next: .tasks/board.json not found — run board-pull first" >&2
  exit 1
fi

if [[ "$JSON_MODE" -eq 1 ]]; then
  jq "[.[] | select(.status==\"$STATUS\")] | .[0] // null" "$BOARD_FILE"
else
  NEXT=$(jq -r "[.[] | select(.status==\"$STATUS\")] | .[0] // empty" "$BOARD_FILE")
  if [[ -z "$NEXT" ]]; then
    echo "(none)"
  else
    number=$(echo "$NEXT" | jq -r '.number // ""')
    id_field=$(echo "$NEXT" | jq -r '.id // ""')
    title=$(echo "$NEXT" | jq -r '.title')
    if [[ -n "$number" ]]; then
      echo "#${number} ${title}"
    else
      echo "${id_field} ${title}"
    fi
  fi
fi
