#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: board-pull [--repo OWNER/REPO] [--label LABELS] [--assignee USER] [--milestone TITLE] [--strategy all-open|labels]

Fetch GitHub issues and write .tasks/issues.json.

Filters:
  --repo OWNER/REPO    Repository (or set BOARD_REPO env var).
  --label LABELS       Comma-separated labels to filter by (OR semantics — issues
                       matching ANY label are returned).
                       Default: inbox,ready,in-progress,needs-review,blocked,needs-info,done
  --assignee USER      Filter by assignee (AND-combined with labels/milestone).
  --milestone TITLE    Filter by milestone title (AND-combined with labels/assignee).
  --strategy STRATEGY  Pull strategy: all-open (default) — one API call + local filter;
                       labels — per-label queries unioned.

At least one of --label, --assignee, or --milestone must be provided
(or already present in the defaults) to scope the pull.
EOF
  exit 0
}

# union_issues: merge multiple JSON arrays, deduplicate by .number, sort by .number.
# Accepts JSON arrays as positional arguments (each a string) and prints a single
# JSON array to stdout. Intentionally a standalone function for testability.
union_issues() {
  if [[ $# -eq 0 ]]; then
    printf '[]\n'
    return
  fi
  printf '%s\n' "$@" | jq -s '
    add
    | unique_by(.number)
    | sort_by(.number)
  '
}

# filter_by_labels: keep issues whose labels intersect the requested set.
# <labels_csv> <issues_json> → prints filtered JSON array (no network, pure jq).
# Empty csv → keep all issues. Issues with no labels are dropped when csv non-empty.
filter_by_labels() {
  local labels_csv="$1" issues_json="$2"

  if [[ -z "$labels_csv" ]]; then
    printf '%s\n' "$issues_json"
    return
  fi

  local labels_json
  labels_json=$(echo "$labels_csv" | tr ',' '\n' | tr -d ' ' | jq -R -s 'split("\n") | map(select(length > 0))')

  echo "$issues_json" | jq --argjson labels "$labels_json" '
    map(select([.labels[].name] as $issue_labels | any($labels[]; . as $lbl | $issue_labels | index($lbl))))
  '
}

# Parse args
REPO="${BOARD_REPO:-}"
LABEL="inbox,ready,in-progress,needs-review,blocked,needs-info,done"
ASSIGNEE=""
MILESTONE=""
STRATEGY="all-open"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --label) LABEL="$2"; shift 2 ;;
    --assignee) ASSIGNEE="$2"; shift 2 ;;
    --milestone) MILESTONE="$2"; shift 2 ;;
    --strategy) STRATEGY="$2"; shift 2 ;;
    --help|-h) usage ;;
    *) echo "Unknown flag: $1"; usage ;;
  esac
done

if [[ -z "$REPO" ]]; then
  echo "ERROR: --repo or BOARD_REPO is required." >&2
  exit 1
fi

if [[ "$STRATEGY" != "all-open" && "$STRATEGY" != "labels" ]]; then
  echo "ERROR: --strategy must be 'all-open' or 'labels'. Got: '$STRATEGY'" >&2
  exit 1
fi

# Check rate limit
rate_limit_json=$(gh api rate_limit 2>/dev/null || true)
if [[ -n "$rate_limit_json" ]]; then
  remaining=$(echo "$rate_limit_json" | jq -r '.resources.core.remaining // 9999')
  if [[ "$remaining" == "0" ]]; then
    reset_ts=$(echo "$rate_limit_json" | jq -r '.resources.core.reset // 0')
    if [[ "$reset_ts" =~ ^[0-9]+$ ]]; then
      reset_time=$(date -r "$reset_ts" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")
      echo "ERROR: GitHub API rate limit exhausted. Resets at $reset_time" >&2
    else
      echo "ERROR: GitHub API rate limit exhausted." >&2
    fi
    exit 1
  fi
else
  echo "WARNING: Could not check rate limit. Proceeding anyway." >&2
fi

# Ensure .tasks directory exists
mkdir -p .tasks

# Build base query args (without label)
base_args=("--repo" "$REPO" "--state" "open" "--json" "number,title,labels,url,assignees,state,updatedAt,body" "--limit" "1000")
declare -a extra_args=()
if [[ -n "$ASSIGNEE" ]]; then
  extra_args+=("--assignee" "$ASSIGNEE")
fi
if [[ -n "$MILESTONE" ]]; then
  extra_args+=("--milestone" "$MILESTONE")
fi

# Split label string into individual labels
IFS=',' read -r -a label_array <<< "$LABEL"

# Trim whitespace from each label
trimmed_labels=()
for lbl in "${label_array[@]}"; do
  trimmed_labels+=("$(echo "$lbl" | tr -d ' ' )")
done

stderr_tmp=$(mktemp)

if [[ "$STRATEGY" == "all-open" ]]; then
  # all-open: one gh call (no --label), then filter locally
  query_args=("${base_args[@]}")
  query_args+=(${extra_args[@]+"${extra_args[@]}"})

  issues_json=$(gh issue list "${query_args[@]}" 2>"$stderr_tmp") || {
    cat "$stderr_tmp" >&2
    rm -f "$stderr_tmp"
    echo "ERROR: Failed to fetch issues" >&2
    exit 1
  }
  issues_json=$(filter_by_labels "$LABEL" "$issues_json")
else
  # labels strategy: original per-label union logic
  if [[ ${#trimmed_labels[@]} -le 1 ]]; then
    # Single label (or none): single query
    query_args=("${base_args[@]}")
    if [[ -n "${trimmed_labels[0]:-}" ]]; then
      query_args+=("--label" "${trimmed_labels[0]}")
    fi
    query_args+=(${extra_args[@]+"${extra_args[@]}"})

    issues_json=$(gh issue list "${query_args[@]}" 2>"$stderr_tmp") || {
      cat "$stderr_tmp" >&2
      rm -f "$stderr_tmp"
      echo "ERROR: Failed to fetch issues" >&2
      exit 1
    }
  else
    # Multiple labels: query each label separately, then union (OR semantics)
    results=()
    for lbl in "${trimmed_labels[@]}"; do
      query_args=("${base_args[@]}" "--label" "$lbl")
      query_args+=(${extra_args[@]+"${extra_args[@]}"})
      result=$(gh issue list "${query_args[@]}" 2>"$stderr_tmp") || {
        cat "$stderr_tmp" >&2
        rm -f "$stderr_tmp"
        echo "ERROR: Failed to fetch issues for label '${lbl}'" >&2
        exit 1
      }
      results+=("$result")
    done
    issues_json=$(union_issues "${results[@]}")
  fi
fi

# Print any captured stderr (warnings, notices) to stderr
if [[ -s "$stderr_tmp" ]]; then
  cat "$stderr_tmp" >&2
fi
rm -f "$stderr_tmp"

# Write to cache file
printf '%s\n' "$issues_json" > .tasks/issues.json

# Print summary to stderr
total=$(echo "$issues_json" | jq '. | length' 2>/dev/null || echo "?")
echo "board-pull: fetched ${total} issues from ${REPO} → .tasks/issues.json" >&2

# Run board-render to generate board.json and TODO.md
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
board_render="${SCRIPT_DIR}/board-render"
if [[ -x "$board_render" ]]; then
  python3 "$board_render"
else
  echo "WARNING: board-render not found at $board_render" >&2
fi
